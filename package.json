{
  "name": "utd-inkformulator-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Aleksey Didenko",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.utd.inkformulatorpro",
    "productName": "UTD Ink Formulator Pro",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": ["portable"],
      "icon": "electron/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
